<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText
            android:id="@+id/et_expense_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Description"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/et_expense_amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Amount (e.g. 150.50)"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/et_expense_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Category Name"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/et_expense_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Date (YYYY-MM-DD)"
            android:inputType="date"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/et_expense_start_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Start Time (HH:MM)"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/et_expense_end_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="End Time (HH:MM)"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btn_pick_photo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Attach Photograph"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tv_photo_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No file selected"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btn_save_expense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Expense"/>
    </LinearLayout>
</ScrollView>